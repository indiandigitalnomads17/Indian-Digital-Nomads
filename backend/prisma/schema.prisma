generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String         @id @default(uuid())
  fullName             String
  email                String         @unique
  passwordHash         String?
  googleId             String?        @unique
  phoneNumber          String?
  role                 UserRole

  status                AccountStatus       @default(ACTIVE)
  kycLogs              KycLog[]            @relation("UserKycLogs")
  adminKycActions      KycLog[]            @relation("AdminKycActions")

  isEmailVerified       Boolean        @default(false)
  isPhoneNumberVerified Boolean        @default(false)
  isVerified           Boolean        @default(false)
  kycStatus            KycStatus      @default(NOT_SUBMITTED)
  govIdStoragePath     String?
  kycNotes             String?
  nomadScore           Decimal        @default(50.00) @db.Decimal(5, 2)
  createdAt            DateTime       @default(now())
  profile              Profile?
  notifications        Notification[]
  jobsAsClient         Job[]          @relation("ClientJobs")
  jobsAsFreelancer     Job[]          @relation("FreelancerJobs")
  proposals            Proposal[]     @relation("FreelancerProposals")
  products             Product[]      @relation("ClientProducts")
  reviewsRec           Review[]       @relation("ReviewsReceived")
  reviewsSent          Review[]       @relation("ReviewsSent")
  transactionsSent     Transaction[]  @relation("TransactionsSent")
  transactionsReceived Transaction[]  @relation("TransactionsReceived")
  verificationTokens    VerificationToken[]
}

model Profile {
  id               String    @id @default(uuid())
  userId           String    @unique
  bio              String?
  profilePicLink   String?
  videoLink        String?
  location         String?
  latitude         Float?
  longitude        Float?
  hourlyRate       Decimal?  @db.Decimal(10, 2)
  isHourly         Boolean   @default(false)
  preferredJobType JobType   @default(FIXED_PRICE)
  bannerLink       String?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects         Project[]
  skills           Skill[]   @relation("ProfileSkills")
}

model Project {
  id          String         @id @default(uuid())
  profileId   String
  title       String
  description String?
  links       String[]       @default([])
  videoUrl    String?
  completedAt DateTime?
  profile     Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  images      ProjectImage[]
  skillsUsed  Skill[]        @relation("ProjectSkills")
}

model ProjectImage {
  id        String   @id @default(uuid())
  url       String
  altText   String?
  projectId String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Job {
  id             String        @id @default(uuid())
  title          String
  description    String
  status         JobStatus     @default(OPEN)
  type           JobType       @default(FIXED_PRICE)
  budget         Decimal?      @db.Decimal(10, 2)
  estimatedHours Int?
  location       String?
  latitude       Float?
  longitude      Float?
  clientId       String
  freelancerId   String?
  createdAt      DateTime      @default(now())
  videoUrl       String?
  client         User          @relation("ClientJobs", fields: [clientId], references: [id], onDelete: Cascade)
  freelancer     User?         @relation("FreelancerJobs", fields: [freelancerId], references: [id])
  images         JobImage[]
  proposals      Proposal[]
  reviews        Review[]
  skillsRequired Skill[]       @relation("JobSkills")
  transactions   Transaction[]
}

model Proposal {
  id            String         @id @default(uuid())
  coverLetter   String
  bidAmount     Decimal        @db.Decimal(10, 2)
  estimatedDays Int?
  status        ProposalStatus @default(PENDING)
  jobId         String
  freelancerId  String
  createdAt     DateTime       @default(now())
  freelancer    User           @relation("FreelancerProposals", fields: [freelancerId], references: [id], onDelete: Cascade)
  job           Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, freelancerId])
}

model Product {
  id              String         @id @default(uuid())
  title           String
  description     String
  price           Decimal        @db.Decimal(10, 2)
  discountedPrice Decimal?       @db.Decimal(10, 2)
  coverImageUrl   String?
  videoUrl        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  clientId        String
  client          User           @relation("ClientProducts", fields: [clientId], references: [id], onDelete: Cascade)
  images          ProductImage[]
  transactions    Transaction[]
  isDelisted      Boolean        @default(false)
  delistReason    String?
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  altText   String?
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Skill {
  id        String    @id @default(uuid())
  name      String    @unique
  tier      Int       @default(1)
  parentId  String?
  parent    Skill?    @relation("SkillHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  subSkills Skill[]   @relation("SkillHierarchy")
  jobs      Job[]     @relation("JobSkills")
  profiles  Profile[] @relation("ProfileSkills")
  projects  Project[] @relation("ProjectSkills")
}

model Review {
  id         String   @id @default(uuid())
  jobId      String
  reviewerId String
  revieweeId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  job        Job      @relation(fields: [jobId], references: [id])
  reviewee   User     @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  reviewer   User     @relation("ReviewsSent", fields: [reviewerId], references: [id])
}

model Transaction {
  id               String            @id @default(uuid())
  gatewayTxId      String            @unique
  type             TransactionType
  status           TransactionStatus @default(PENDING)
  paymentMethod    PaymentMethod
  amount           Decimal           @db.Decimal(10, 2)
  feeAmount        Decimal           @default(0.00) @db.Decimal(10, 2)
  netAmount        Decimal           @db.Decimal(10, 2)
  currency         String            @default("USD")
  billingCountry   String?
  invoiceUrl       String?
  failureReason    String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  senderId         String?
  sender           User?             @relation("TransactionsSent", fields: [senderId], references: [id], onDelete: SetNull)
  receiverId       String?
  receiver         User?             @relation("TransactionsReceived", fields: [receiverId], references: [id], onDelete: SetNull)
  jobId            String?
  job              Job?              @relation(fields: [jobId], references: [id], onDelete: SetNull)
  productId        String?
  product          Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model KycLog {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation("UserKycLogs", fields: [userId], references: [id], onDelete: Cascade)
  adminId     String
  admin       User      @relation("AdminKycActions", fields: [adminId], references: [id], onDelete: Cascade)
  status      KycStatus // APPROVED or REJECTED
  notes       String?   // Copy of kycNotes explaining the decision
  createdAt   DateTime  @default(now()) // Serves as the "verifiedAt" timestamp
}

model Session {
  id        String   @id @map("sid")
  expiresAt DateTime @map("expire")
  data      String   @map("sess")

  @@map("Session")
}

model JobImage {
  id        String   @id @default(uuid())
  url       String
  jobId     String
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      TokenType
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Ensure a user can only have one active token per verification channel at a time
  @@unique([userId, type])
}

enum TokenType {
  EMAIL_OTP
  PHONE_OTP
}


enum UserRole {
  CLIENT
  FREELANCER
  SUPPORT
  ADMIN
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum JobType {
  FIXED_PRICE
  HOURLY
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  PAYPAL
  CRYPTO
  WALLET_BALANCE
}

enum TransactionStatus {
  PENDING
  SUCCESSFUL
  FAILED
  REFUNDED
}

enum TransactionType {
  DEPOSIT
  PAYOUT
  COMMISSION
  REFUND
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum AccountStatus {
  ACTIVE
  DEACTIVATED
  SUSPENDED
}