generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum UserRole {
  CLIENT
  FREELANCER
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum JobType {
  FIXED_PRICE
  HOURLY
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

// --- Models ---

model User {
  id            String    @id @default(uuid())
  fullName      String
  email         String    @unique
  passwordHash  String?
  googleId      String?   @unique
  phoneNumber   String?
  role          UserRole
  createdAt     DateTime  @default(now())

  profile       Profile?
  
  jobsAsClient     Job[]      @relation("ClientJobs")
  jobsAsFreelancer Job[]      @relation("FreelancerJobs")
  proposals        Proposal[] @relation("FreelancerProposals")
  
  reviewsSent      Review[]   @relation("ReviewsSent")
  reviewsRec       Review[]   @relation("ReviewsReceived")
}

model Profile {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bio            String?
  profilePicLink String?
  videoLink      String?
  
  // Geolocation
  location       String?
  latitude       Float?
  longitude      Float?
  
  projects       Project[]
  skills         Skill[]   @relation("ProfileSkills")
}

model Project {
  id          String         @id @default(uuid())
  profileId   String
  profile     Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  projectUrl  String?   
  videoUrl    String?   
  
  // NEW: A project can have many screenshots
  images      ProjectImage[] 
  
  skillsUsed  Skill[]        @relation("ProjectSkills")
  completedAt DateTime?
}

model ProjectImage {
  id        String   @id @default(uuid())
  url       String   // The link to the hosted image
  altText   String?  // Good for SEO and accessibility
  
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

model Job {
  id             String    @id @default(uuid())
  title          String
  description    String
  status         JobStatus @default(OPEN)
  
  // Payment Logic
  type           JobType   @default(FIXED_PRICE)
  budget         Decimal?  @db.Decimal(10, 2)
  estimatedHours Int?
  
  // Geolocation
  location       String?
  latitude       Float?
  longitude      Float?

  // Relations
  clientId       String
  client         User      @relation("ClientJobs", fields: [clientId], references: [id], onDelete: Cascade)
  
  freelancerId   String?
  freelancer     User?     @relation("FreelancerJobs", fields: [freelancerId], references: [id])
  
  proposals      Proposal[]
  skillsRequired Skill[]    @relation("JobSkills")
  reviews        Review[]
  
  createdAt      DateTime  @default(now())
}

model Proposal {
  id            String         @id @default(uuid())
  coverLetter   String         @db.Text
  bidAmount     Decimal        @db.Decimal(10, 2)
  estimatedDays Int?
  status        ProposalStatus @default(PENDING)
  
  jobId         String
  job           Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  freelancerId  String
  freelancer    User           @relation("FreelancerProposals", fields: [freelancerId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime       @default(now())

  @@unique([jobId, freelancerId])
}

model Skill {
  id          String    @id @default(uuid())
  name        String    @unique
  
  parentId    String?
  parent      Skill?    @relation("SkillHierarchy", fields: [parentId], references: [id])
  subSkills   Skill[]   @relation("SkillHierarchy")

  profiles    Profile[] @relation("ProfileSkills")
  jobs        Job[]     @relation("JobSkills")


  projects    Project[] @relation("ProjectSkills") 
}

model Review {
  id           String   @id @default(uuid())
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id])
  
  reviewerId   String
  reviewer     User     @relation("ReviewsSent", fields: [reviewerId], references: [id])
  
  revieweeId   String
  reviewee     User     @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  
  rating       Int
  comment      String?
  createdAt    DateTime @default(now())
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String   // This stores the stringified session data
  expiresAt DateTime
}